{
  "compilerOptions": {
    "target": "ES2015",
    "lib": [ "ES2015", "DOM", "DOM.Iterable", "ScriptHost" ],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "*": [ "node_modules/*" ]
    },
    "noEmit": true
  },
  "exclude": [ "node_modules", "bin", "obj" ]
}